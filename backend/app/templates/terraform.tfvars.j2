block_all_traffic_rule = <<EOT
# Default deny rule for all traffic
# drop tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"Default deny new outbound TCP"; flow:to_server, established; sid:9999; rev:2;)
EOT

advanced_ids_rules = <<EOT
# Basic IDS rules - Minimal guaranteed baseline

# Basic Log4j detection
alert http any any -> any any (msg:"Log4j exploitation attempt"; flow:established,to_server; content:"jndi:"; nocase; sid:99000001; rev:1;)

# Basic SQL Injection detection
alert http any any -> any any (msg:"SQL Injection attempt"; flow:established,to_server; content:"'"; content:" or 1=1"; nocase; sid:99000002; rev:1;)

# Suspicious User-Agent detection
alert http any any -> any any (msg:"Suspicious User-Agent"; flow:established,to_server; content:"curl"; nocase; sid:99000003; rev:1;)

# Non-standard SSH port detection
alert tcp any any -> any !22 (msg:"SSH on non-standard port"; flow:established,to_server; content:"SSH-"; depth:4; sid:99000004; rev:1;)
EOT

threat_detection_rules = <<EOT
# Basic threat detection rules

# Obsolete TLS detection
reject tls any any -> any any (msg:"TLS 1.0/1.1 detected"; flow:established; content:"|03 01|"; depth:2; sid:2023001; rev:1;)

# High-risk port blocking
drop tcp any any -> any [445,135,139,3389] (msg:"High-risk port blocked"; sid:2023002; rev:1;)

# Simple port scanning detection
alert tcp any any -> any any (msg:"Possible port scanning"; flags:S; flow:stateless; sid:2023003; rev:1;)
EOT
{% if create_eks %}

# ---------------------------------------------------------------------------------------------
# EKS Cluster
# ---------------------------------------------------------------------------------------------
argocd_mgmt_account_id = "{{ eks_argocd_mgmt_account_id }}"

eks_clusters = {
  "{{ eks_cluster_name }}" = {
    create_eks_module = true

    # Cluster settings
    create_argocd              = {{ eks_create_argocd | lower }}
    cluster_name               = "{{ eks_cluster_name }}"
    cluster_version            = "{{ eks_cluster_version }}"
    cluster_enabled_log_types  = [{{ eks_cluster_enabled_log_types_formatted }}]
    authentication_mode        = "{{ eks_authentication_mode }}"
    endpoint_private_access    = {{ eks_endpoint_private_access | lower }}
    endpoint_public_access     = {{ eks_endpoint_public_access | lower }}
    create_nlb_for_eks_cluster = {{ eks_create_nlb_for_eks_cluster | lower }}

    # EKS OIDC settings
    oidc_client_id_list  = ["sts.amazonaws.com"]
    oidc_thumbprint_list = ["6938fd4d98bab03faadb97b34396831e3780aea1"]

    # IAM SSO access settings
    iam_access = {
      admin_sso = {
        role = "{{ eks_iam_admin_sso_role_arn }}"
        policies = {
          cluster = "AmazonEKSClusterAdminPolicy"
        }
      }
    }
    iam_roles_path = "{{ eks_iam_roles_path }}"

    # Node Group settings
    create_nodegroup = {{ eks_create_nodegroup | lower }}

    # Cluster Add-ons settings
    cluster_public_access_cidrs = [{{ eks_cluster_public_access_cidrs_formatted }}]

    # CoreDNS settings
    create_coredns  = true
    coredns_version = "{{ eks_coredns_version }}"
    coredns_config_values = {
      computeType = "Fargate"
    }
    coredns_sa_role_arn    = null
    create_fargate_coredns = true

    # Kube-proxy settings
    create_kubeproxy        = true
    kubeproxy_version       = "{{ eks_kubeproxy_version }}"
    kubeproxy_config_values = {}
    kubeproxy_sa_role_arn   = null

    # VPC-CNI settings
    create_vpccni  = true
    vpccni_version = "{{ eks_vpccni_version }}"
    vpccni_config_values = {
      env = {
        ENABLE_PREFIX_DELEGATION = "false"
        WARM_PREFIX_TARGET       = "1"
        WARM_ENI_TARGET          = "0"
        MINIMUM_IP_TARGET        = "0"
      }
      enableWindowsIpam             = "true"
      enableWindowsPrefixDelegation = "false"
      warmWindowsIPTarget           = 1
      minimumWindowsIPTarget        = 3
    }
    vpccni_sa_role_arn = null

    # EBS-CSI settings
    create_ebscsi        = {{ eks_create_ebscsi | lower }}
    ebscsi_version       = "{{ eks_ebscsi_version }}"
    ebscsi_config_values = {}

    # Mountpoint S3 CSI settings
    create_mountpoint_s3_csi  = true
    mountpoint_s3_csi_version = "{{ eks_mountpoint_s3_csi_version }}"
    mountpoint_s3_csi_config_values = {
      node = {
        tolerateAllTaints = true
      }
    }
    mountpoint_s3_csi_sa_role_arn = "{{ eks_mountpoint_s3_csi_sa_role_arn }}"

    # Networking arguments
    pci_cluster                      = {{ eks_pci_cluster | lower }}
    enable_cross_zone_load_balancing = {{ eks_enable_cross_zone_load_balancing | lower }}

    # Additional tags for this specific cluster
    additional_tags = {
      Environment = "{{ environment_name }}"
      Terraform   = "true"
    }
  }
}
{% endif %}
