environment   = "{{ environment_name }}"
business      = "{{ business }}"
platform_name = "{{ platform_name }}"

tags = {
  Environment = "{{ environment_name }}"
  Team        = "{{ business }}"
  Application = "EKS"
  Terraform   = "true"
}

create_cross_cluster_iam = {{ create_cross_cluster_iam | lower }}
deploy_api_gateway       = {{ deploy_api_gateway | lower }}

app_config_management = {
  create = {{ app_config_create | lower }}
  sops_kms_key = {
    deletion_window_in_days = {{ sops_kms_deletion_window }}
    create_replica          = {{ sops_kms_create_replica | lower }}
  }
  github_actions_org_repo_name_list = [{{ github_actions_org_repo_list_formatted }}]
}

# --------------------------------------------------------------------------------------------
# Bastion Configuration
# --------------------------------------------------------------------------------------------
bastion_configuration = {
  deploy_bastion         = {{ deploy_bastion | lower }}
  ami_id                 = "{{ bastion_ami_id }}"
  instance_type          = "{{ bastion_instance_type }}"
  name                   = "{{ bastion_name }}"
  egress_cidr_blocks     = [{{ bastion_egress_cidr_formatted }}]
  egress_security_groups = [{{ bastion_egress_sgs_formatted }}]
  iam_role_path          = "{{ bastion_iam_role_path }}"
}

# ---------------------------------------------------------------------------------------
# VPC {{ vpc_primary_region }}
# ---------------------------------------------------------------------------------------
vpc_primary = {
  ### Module Controls
  create_vpc                       = {{ create_vpc_primary | lower }}
  create_internet_gateway          = {{ vpc_create_internet_gateway | lower }}
  create_nat_gateway               = {{ vpc_create_nat_gateway | lower }}
  create_vpc_endpoints             = {{ vpc_create_vpc_endpoints | lower }}
  create_egress_network_firewall   = {{ vpc_create_egress_firewall | lower }}
  create_eks_control_plane_subnets = {{ vpc_create_eks_cp_subnets | lower }}

  ### Availability Zones
  availability_zones = [{{ vpc_primary_azs_formatted }}]

  ### Basic VPC Configuration
  environment_tier    = "{{ environment_tier }}"
  vpc_type            = "workload"
  ipam_pool_name      = "{{ vpc_ipam_pool_name }}"
  ipv4_netmask_length = {{ vpc_primary_netmask }}
  workload_subnet_cidrs = {
    app               = { "newbits" = 4, "netnum" = 0 }   # /23
    secure            = { "newbits" = 5, "netnum" = 6 }   # /24
    frontend          = { "newbits" = 5, "netnum" = 9 }   # /24
    dmz               = { "newbits" = 5, "netnum" = 12 }  # /24
    mbo               = { "newbits" = 5, "netnum" = 15 }  # /24
    eks_control_plane = { "newbits" = 5, "netnum" = 18 }  # /24
    aws_services      = { "newbits" = 8, "netnum" = 168 } # /27
    waf               = { "newbits" = 8, "netnum" = 171 } # /27
    vwan              = { "newbits" = 8, "netnum" = 174 } # /27
    firewall          = { "newbits" = 8, "netnum" = 177 } # /27
  }
  nat_gateway_deployment = "{{ vpc_nat_gw_deployment }}"
  vpc_endpoints          = [{{ vpc_endpoints_primary_formatted }}]

  ### Optional configurations
  enable_flow_logs         = {{ vpc_enable_flow_logs | lower }}
  flow_logs_retention_days = {{ vpc_flow_logs_retention }}

  ### Transit Gateway Configuration
  attach_to_transit_gateway                 = {{ vpc_attach_tgw | lower }}
  transit_gateway_route_table_to_attach     = "{{ vpc_tgw_rt_attach }}"
  transit_gateway_route_tables_to_propagate = [{{ vpc_tgw_rt_propagate_formatted }}]
  tgw_subnet_names                          = [{{ vpc_tgw_subnet_names_formatted }}]
  tgw_destination_cidrs                     = [{{ vpc_tgw_dest_cidrs_formatted }}]

  ### Private Hosted Zone Configuration
  associate_with_private_hosted_zones        = {{ vpc_associate_phz | lower }}
  private_hosted_zones_prod_to_associate     = []
  private_hosted_zones_non_prod_to_associate = ["{{ phz_domain }}"]
  connect_to_phz                             = {{ vpc_connect_to_phz | lower }}

  app_subnet_custom_tags = {
    "{{ app_subnet_tag_role_key }}"    = "{{ app_subnet_tag_role_value }}"
    "{{ app_subnet_tag_cluster_key }}" = "{{ app_subnet_tag_cluster_value }}"
  }
}
