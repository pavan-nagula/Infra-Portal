# ============================================
# Infra Portal Backend — Environment Variables
# ============================================

# --- Application ---
ENV=development
APP_NAME=infra-portal-backend
APP_VERSION=1.0.0

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- GitHub (Terraform repo) ---
# Leave GITHUB_TOKEN empty to run in MOCK MODE (no real GitHub calls)
GITHUB_TOKEN=
GITHUB_ORG=cubic-aws
GITHUB_REPO=terraform-cts-umb-internal
GITHUB_BASE_BRANCH=main

# --- GitHub (ArgoCD app-of-apps repo for cluster registration) ---
ARGOCD_GITHUB_REPO=argocd-cts-umb-app-of-apps
ARGOCD_GITHUB_BASE_BRANCH=gotham

# --- Optional: local path to the terraform repo (enables GET /environments fallback) ---
# TERRAFORM_REPO_PATH=D:/Jira/My Tickets/internal-qa-infra-provision/terraform-cts-umb-internal-boil

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Security ---
# When SECURITY_ENABLED=true, all /api/v1/* requests require X-API-Key header
SECURITY_ENABLED=false
API_KEY=

# --- Rate Limiting (per IP) ---
RATE_LIMIT_PER_MINUTE=60
